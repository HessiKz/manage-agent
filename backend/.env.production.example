# Production backend — copy to backend/.env on the server:
#   cp backend/.env.production.example backend/.env

APP_NAME=manage-agent
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# openssl rand -hex 32
SECRET_KEY=REPLACE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set true when the Next.js app is hosted on Vercel (*.vercel.app previews)
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Set true when the Next.js app is hosted on Railway (*.up.railway.app)
# CORS_ALLOW_RAILWAY_DOMAINS=true

DATABASE_URL=postgresql+asyncpg://manage_agent:REPLACE@postgres:5432/manage_agent
DATABASE_SYNC_URL=postgresql+psycopg2://manage_agent:REPLACE@postgres:5432/manage_agent

REDIS_URL=redis://:REPLACE@redis:6379/0

# LLM gateway (required unless using cursor-to-api only)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=claude-opus-4-7
AGENT_VALIDATION_TIMEOUT_SECONDS=600

# cursor-to-api (optional — enable COMPOSE_PROFILES=cursor in root .env)
CURSOR_API_BASE_URL=http://cursor-to-api:9191/api/v1
CURSOR_API_KEY=
CURSOR_API_MODEL=auto

LOG_LEVEL=INFO
LOG_JSON=true
LOG_CLIENT_ERRORS=true
RATE_LIMIT_PER_MINUTE=120

# Change before first login!
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=REPLACE_STRONG_PASSWORD
FIRST_ADMIN_NAME=System Admin
