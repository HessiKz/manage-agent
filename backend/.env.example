# ─── App ─────────────────────────────────────────────────
APP_NAME=manage-agent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# ─── Security ────────────────────────────────────────────
# Generate a strong secret: `openssl rand -hex 32`
SECRET_KEY=change-me-please-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── CORS (comma-separated; dev also allows regex in main.py) ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# ─── Database ────────────────────────────────────────────
# (compose overrides this with asyncpg URL; for local dev set explicitly)
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/manage_agent
# Sync URL for alembic
DATABASE_SYNC_URL=postgresql+psycopg2://admin:admin@localhost:5432/manage_agent

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://:redis@localhost:6379/0

# ─── LLM providers ───────────────────────────────────────
# Use an OpenAI-compatible gateway by setting OPENAI_BASE_URL (optional).
# Example for gapgpt: https://api.gapgpt.app/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
AGENT_VALIDATION_TIMEOUT_SECONDS=180

# cursor-to-api (local OpenAI-compatible proxy — toggle active provider in Admin)
# Run: cd ../cursor-to-api && python -m venv .venv && .venv/bin/pip install -r requirements.txt && .venv/bin/python -m cursor_to_api.main
CURSOR_API_BASE_URL=http://127.0.0.1:9191/api/v1
CURSOR_API_KEY=
CURSOR_API_MODEL=auto
# LLM_PROVIDER=gateway   # default; admin panel persists choice in platform_settings

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
# LOG_FILE=var/logs/manage-agent.log
LOG_CLIENT_ERRORS=true

# ─── Rate limit ──────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ─── Initial admin user (seed) ───────────────────────────
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=admin123
FIRST_ADMIN_NAME=System Admin
