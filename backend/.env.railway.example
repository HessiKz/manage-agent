# Railway API service — paste into Railway Variables (dashboard).
# Root Directory for this service: backend

APP_ENV=production
APP_DEBUG=false

# openssl rand -hex 32
SECRET_KEY=REPLACE_ME

# Reference plugins (adjust service names to match your project):
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}
# DATABASE_SYNC_URL is optional — derived from DATABASE_URL when unset

# Frontend origin(s), comma-separated
CORS_ORIGINS=https://your-app.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=true
CORS_ALLOW_RAILWAY_DOMAINS=true

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=claude-opus-4-7
AGENT_VALIDATION_TIMEOUT_SECONDS=600

FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=REPLACE_STRONG_PASSWORD
FIRST_ADMIN_NAME=System Admin

LOG_LEVEL=INFO
LOG_JSON=true
LOG_CLIENT_ERRORS=true
RATE_LIMIT_PER_MINUTE=120
