# Copy values into Vercel → Project → Settings → Environment Variables
# Apply to Production + Preview

# ─── Option A (recommended): browser calls API directly — best for long LLM runs ───
# Your hosted FastAPI URL (Railway, Render, Fly.io, etc.) — no trailing slash
# Railway example: https://manage-agent-api-production.up.railway.app
NEXT_PUBLIC_API_URL=https://your-api.example.com

# Backend CORS must include your Vercel URL, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main-you.vercel.app

# ─── Option B: same-origin proxy via Vercel rewrites (shorter proxy timeout on Hobby) ───
# Leave NEXT_PUBLIC_API_URL empty/unset and set:
# INTERNAL_API_URL=https://your-api.example.com

# ─── Shared ───────────────────────────────────────────────────
NEXT_PUBLIC_LOG_CLIENT_ERRORS=true
NEXT_PUBLIC_API_TIMEOUT_MS=30000
NEXT_PUBLIC_API_LONG_TIMEOUT_MS=600000
