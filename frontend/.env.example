# Local dev (make dev): leave empty — dev.sh sets http://127.0.0.1:8000 automatically.
# Docker compose: use http://localhost:8000 or same-origin via INTERNAL_API_URL rewrites.
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000
# Send warn/error logs to backend (POST /api/v1/logs/client)
NEXT_PUBLIC_LOG_CLIENT_ERRORS=true

# Optional timeouts (ms) — agent invoke uses LONG timeout
# NEXT_PUBLIC_API_TIMEOUT_MS=30000
# NEXT_PUBLIC_API_LONG_TIMEOUT_MS=600000
