# Copy to .env in repo root for production Docker Compose:
#   cp .env.example .env && nano .env

# Public URL (no trailing slash) — used for CORS and frontend API calls
# Examples: https://agents.example.com  or  http://203.0.113.10
PUBLIC_URL=http://localhost

# Database (postgres service)
POSTGRES_DB=manage_agent
POSTGRES_USER=manage_agent
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-16

# Redis
REDIS_PASSWORD=change-me-use-openssl-rand-hex-16

# Optional: enable cursor-to-api sidecar (requires Cursor agent CLI in image/host — off by default)
# COMPOSE_PROFILES=cursor
